@model IEnumerable<ImobiliariaMVC.Models.Imovel>

@{
    ViewData["Title"] = "Lista de Imóveis";
}


<div class="container mt-4">

    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold text-center">
                <i class="bi bi-buildings"></i> Lista de Imóveis
            </h2>
            <hr />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 mb-2">
            <a class="btn btn-dourado w-100" href="/Imovel/Create">
                Cadastrar Novo Imóvel
            </a>
        </div>

        <div class="col-md-6">
            <form method="get" action="/Imovel/Search" class="d-flex">
                <input type="text" name="termo" class="form-control me-2" placeholder="Buscar por título..." />
                <button type="submit" class="btn btn-dourado">Buscar</button>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table tabela-imoveis align-middle text-center">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Categoria</th>
                    <th>Negócio</th>
                    <th>Ações</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Titulo</td>

                            <td>
                                <span class="badge-detalhes">@item.Categoria</span>
                            </td>

                            <td>
                                <span class="badge-detalhes">@item.TipoNegocio</span>
                            </td>

                            <td>
                                <div class="d-flex justify-content-center gap-2">

                                    <a href="/Imovel/Details/@item.Id" class="btn btn-sm btn-detalhes">

                                        <i class="bi bi-eye-fill"></i>
                                        Detalhes

                                    </a>

                                    <a href="/Imovel/Edit/@item.Id" class="btn btn-sm btn-detalhes">

                                        <i class="bi bi-pencil-square"></i>
                                        Editar

                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" style="color:#d4af37;">
                            Nenhum imóvel cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>